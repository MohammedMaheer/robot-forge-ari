# ============================================================================
# ROBOTFORGE — Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================================

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://robotforge:robotforge_dev@localhost:5432/robotforge
POSTGRES_USER=robotforge
POSTGRES_PASSWORD=robotforge_dev
POSTGRES_DB=robotforge

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── MinIO (S3-compatible) ─────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=robotforge
MINIO_SECRET_KEY=robotforge_dev_secret
MINIO_BUCKET=robotforge-dev

# ── RabbitMQ ───────────────────────────────────────────────
RABBITMQ_URL=amqp://robotforge:robotforge_dev@localhost:5672
RABBITMQ_USER=robotforge
RABBITMQ_PASS=robotforge_dev

# ── Elasticsearch ──────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ── LiveKit ────────────────────────────────────────────────
LIVEKIT_HOST=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret1234567890abcdef

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET=robotforge_jwt_secret_change_in_production
JWT_REFRESH_SECRET=robotforge_refresh_secret_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_STARTER_PRICE_ID=price_REPLACE_ME
STRIPE_PROFESSIONAL_PRICE_ID=price_REPLACE_ME

# ── Service URLs ───────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:3001
COLLECTION_SERVICE_URL=http://localhost:8001
PROCESSING_SERVICE_URL=http://localhost:8002
PACKAGING_SERVICE_URL=http://localhost:8003
MARKETPLACE_SERVICE_URL=http://localhost:3002
GATEWAY_URL=http://localhost:3000

# ── Web App ────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api
VITE_LIVEKIT_URL=ws://localhost:7880
VITE_WS_URL=http://localhost:3000

# ── OAuth (GitHub) ─────────────────────────────────────────
GITHUB_CLIENT_ID=REPLACE_ME
GITHUB_CLIENT_SECRET=REPLACE_ME
GITHUB_CALLBACK_URL=http://localhost:3001/oauth/github/callback

# ── OAuth (Google) ─────────────────────────────────────────
GOOGLE_CLIENT_ID=REPLACE_ME
GOOGLE_CLIENT_SECRET=REPLACE_ME
GOOGLE_CALLBACK_URL=http://localhost:3001/oauth/google/callback

# ── CORS & App ─────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# ── Notification Service ───────────────────────────────────
NOTIFICATION_SERVICE_PORT=3003
INTERNAL_SECRET=robotforge_internal_dev_secret

# ── Streaming Service ──────────────────────────────────────
STREAMING_SERVICE_PORT=3004
