datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

model Dataset {
  id                 String    @id @default(uuid())
  name               String
  description        String
  ownerId            String    @map("owner_id")
  task               String
  embodiments        String[]
  episodeCount       Int       @default(0) @map("episode_count")
  totalDurationHours Float     @default(0) @map("total_duration_hours")
  sizeGb             Float     @default(0) @map("size_gb")
  qualityScore       Float     @default(0) @map("quality_score")
  format             String    @default("robotforge_native")
  pricingTier        String    @default("free") @map("pricing_tier")
  pricePerEpisode    Int?      @map("price_per_episode") // cents
  tags               String[]
  downloads          Int       @default(0)
  rating             Float     @default(0)
  accessLevel        String    @default("public") @map("access_level")
  licenseType        String    @default("cc_by") @map("license_type")
  storageUrl         String?   @map("storage_url")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  reviews   Review[]
  purchases Purchase[]
  cartItems CartItem[]
  provenance ProvenanceEvent[]

  @@index([ownerId])
  @@index([task])
  @@index([pricingTier])
  @@index([accessLevel])
  @@index([qualityScore])
  @@index([downloads])
  @@index([updatedAt])
  @@map("datasets")
}

model Review {
  id        String   @id @default(uuid())
  datasetId String   @map("dataset_id")
  userId    String   @map("user_id")
  userName  String   @map("user_name")
  rating    Int      // 1-5
  comment   String
  createdAt DateTime @default(now()) @map("created_at")

  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([datasetId])
  @@unique([datasetId, userId])
  @@map("reviews")
}

model Purchase {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  datasetId       String   @map("dataset_id")
  amount          Int      // cents
  currency        String   @default("usd")
  stripePaymentId String?  @unique @map("stripe_payment_id")
  status          String   @default("pending") // pending | completed | refunded
  createdAt       DateTime @default(now()) @map("created_at")

  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([datasetId])
  @@map("purchases")
}

// ---------------------------------------------------------------------------
// Cart
// ---------------------------------------------------------------------------

model CartItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  datasetId String   @map("dataset_id")
  addedAt   DateTime @default(now()) @map("added_at")

  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([userId, datasetId])
  @@index([userId])
  @@map("cart_items")
}

// ---------------------------------------------------------------------------
// Data Provenance (Spec §5 Step 3.3 — lineage tracking)
// ---------------------------------------------------------------------------

model ProvenanceEvent {
  id        String   @id @default(uuid())
  datasetId String   @map("dataset_id")
  actor     String   // user ID or "system"
  action    String   // created | episodes_added | quality_rescored | format_converted | published | downloaded | forked | license_changed
  details   Json?    // free-form metadata about the event
  parentId  String?  @map("parent_id") // link to parent event for DAG lineage
  createdAt DateTime @default(now()) @map("created_at")

  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  parent  ProvenanceEvent?  @relation("ProvenanceChain", fields: [parentId], references: [id])
  children ProvenanceEvent[] @relation("ProvenanceChain")

  @@index([datasetId])
  @@index([actor])
  @@map("provenance_events")
}
